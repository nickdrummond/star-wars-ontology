         rdf:type owl:Class
        ]
    ] ,
  [ rdf:type owl:Restriction ;
     owl:onProperty :included ;
     owl:someValuesFrom [ owl:intersectionOf ( :Conversation
             [ rdf:type owl:Restriction ;
                owl:onProperty :about ;
                owl:someValuesFrom [ owl:intersectionOf ( :Execution
                        [ rdf:type owl:Restriction ;
                           owl:onProperty :of ;
                           owl:hasValue :Lee-Char
                          ]
                       ) ;
                    rdf:type owl:Class
