<https://nickdrummond.github.io/star-wars-ontology/ontologies/clone-wars-4.owl.ttl> rdf:type owl:Ontology ;
 owl:imports <https://nickdrummond.github.io/star-wars-ontology/ontologies/star-wars.owl.ttl> ;
