 rdfs:seeAlso "https://nickdrummond.github.io/star-wars-ontology/"^^xsd:anyURI ,
  "https://starwars.fandom.com/wiki/The_Clone_Wars:_Season_Four"^^xsd:anyURI .

:Anakin_follows_Rish_Loo rdf:type owl:NamedIndividual ,
  :Chase ,
  [ rdf:type owl:Restriction ;
     owl:onProperty :included ;
     owl:someValuesFrom [ owl:intersectionOf ( :Attack
             :Killing
             [ rdf:type owl:Restriction ;
                owl:onProperty :of ;
                owl:someValuesFrom :Kaadu
               ]
             [ rdf:type owl:Restriction ;
                owl:onProperty :participant ;
                owl:someValuesFrom :Probe_Droid
               ]
            ) ;
         rdf:type owl:Class
        ]
    ] ,
  [ rdf:type owl:Restriction ;
     owl:onProperty :used ;
     owl:someValuesFrom :Kaadu
    ] ;
 :after :Mustering_the_Gungan_Army ;
 :at :Naboo ;
 :during :Investigating_unrest_on_Naboo ;
 :participant :Anakin_Skywalker ;
 :target :Rish_Loo ;
 :year -20 ;
 rdfs:label "Anakin follows Rish Loo"@en ;
 rdfs:seeAlso "https://starwars.fandom.com/wiki/Shadow_Warrior"^^xsd:anyURI ;
 util:editorLabel "Anakin_follows_Rish_Loo" ;
 util:legacyId "68597042" .


:Appealing_to_the_Quarren rdf:type owl:NamedIndividual ,
  :Speech ,
  [ rdf:type owl:Restriction ;
     owl:onProperty :about ;
     owl:someValuesFrom [ owl:intersectionOf ( :Quarren
             [ rdf:type owl:Restriction ;
                owl:onProperty :hadRole ;
                owl:someValuesFrom :Slave
               ]
            ) ;
         rdf:type owl:Class
        ]
    ] ,
  [ rdf:type owl:Restriction ;
     owl:onProperty :included ;
     owl:someValuesFrom [ owl:intersectionOf ( :Conversation
             [ rdf:type owl:Restriction ;
                owl:onProperty :about ;
                owl:someValuesFrom [ owl:intersectionOf ( :Execution
                        [ rdf:type owl:Restriction ;
                           owl:onProperty :of ;
                           owl:hasValue :Lee-Char
                          ]
                       ) ;
                    rdf:type owl:Class
                   ]
               ]
             [ rdf:type owl:Restriction ;
                owl:onProperty :orderedBy ;
                owl:hasValue :Riff_Tamson
               ]
            ) ;
         rdf:type owl:Class
        ]
    ] ;
 :after :Infiltrating_the_Mon_Cala_internement_camp ;
 :at :Mon_Cala ;
 :during :Battle_of_Mon_Cala ;
 :participant :Lee-Char ;
 :witnessedBy :Nossor_Ri ;
 :year -20 ;
 rdfs:label "Appealing to the Quarren"@en ;
 rdfs:seeAlso "https://starwars.fandom.com/wiki/Prisoners"^^xsd:anyURI ;
 util:editorLabel "Appealing_to_the_Quarren" ;
 util:legacyId "1370793785" .


